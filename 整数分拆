#include<stdio.h>
int a[100];
int ll = 0;
void dfs(int m, int step, int n)
{
	//不用分解
	if (m <= 0)//数已经分解完了
	{
		if (step - 1 == 1)
		{
			printf("%d=%d\n", n, n);
		}
		else
		{
			printf("%d=", n);
			printf("%d", a[1]);
			for (int i = 2; i < step; i++)
			{
				printf("+%d", a[i]);
			}
			ll++;
			if (ll == 4)
			{
				printf("\n");
				ll = 0;
			}
			else if (ll != 4) printf(";");
		}
	}
	//需要分解，枚举当前数字。
	else
	{
		//可以改成i=1，就代表6 1这样重复的都行。
		for (int i = a[step - 1]; i <= m; i++)
		{
			a[step] = i;
			dfs(m - i, step + 1, n);
		}
	}
}
int main()
{
	int n;
	scanf("%d", &n);
	a[0] = 1;
	dfs(n, 1, n);
	return 0;
}
